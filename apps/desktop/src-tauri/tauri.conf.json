{
  "project_name": "ClawShield",
  "identifier": "com.clawshield.app",
  "version": "0.1.0",
  "productName": "ClawShield",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "ClawShield Control Panel",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ws://localhost:4000 http://localhost:4001"
    }
  },
  "bundle": {
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "identifier": "com.clawshield.app",
    "active": true,
    "category": "DeveloperTool",
    "copyright": "MIT",
    "targets": ["all"]
  }
}
