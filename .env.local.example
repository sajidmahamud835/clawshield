# ClawShield Local Environment Configuration
# Template file - Do not place real secrets here directly. 
# Setup wizard or user should duplicate this to .env.local

# Agent Authentication
# Hardware-bound secret used to issue mobile JWTs. Populated automatically by the setup wizard/installer.
CLAWSHIELD_AGENT_SECRET=change_me_in_production

# Voice Pipeline Configurations
# Mode: "local" (uses whisper.cpp if GPU available) or "api" (uses OpenAI Whisper)
WHISPER_MODE=local

# ----------------------------------------
# 3rd Party API Keys (User provided via Setup Wizard)
# ----------------------------------------

# Fallback for voice transcription
OPENAI_API_KEY=""

# ElevenLabs Turbo v2.5 TTS
ELEVENLABS_API_KEY=""

# Claude intent extraction & generation
ANTHROPIC_API_KEY=""
